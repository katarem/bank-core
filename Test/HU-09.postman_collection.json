  "item": [
    {
      "name": "Account Withdrawal",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.expect(pm.response.code).to.eql(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Transaction type is WITHDRAWAL\", () => {\r",
              "    pm.expect(pm.response.json().type).to.eql(\"WITHDRAWAL\");\r",
              "    });\r",
              " pm.test(\"Response body contains amount field\", () => {\r",
              "    const response = pm.response.json();\r",
              "    pm.expect(response.amount).to.be.a(\"number\");\r",
              "    pm.expect(response.amount).to.not.be.a(\"string\");\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{USER_TOKEN}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n\"amount\": 500,\r\n\"description\": \"Retiro cajero automático\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{ACCOUNT_URL}}/api/accounts/{{ACCOUNT_ID}}/withdraw",
          "host": [
            "{{ACCOUNT_URL}}"
          ],
          "path": [
            "api",
            "accounts",
            "{{ACCOUNT_ID}}",
            "withdraw"
          ]
        }
      },
      "response": []
    },
