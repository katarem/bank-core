  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "Create account Copy",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", () => {\r",
                  "   pm.expect(pm.response.code).to.eql(201);\r",
                  "});\r",
                  "pm.test(\"Response has account id\", () => {\r",
                  "    const response = pm.response.json(); \r",
                  "        pm.expect(response).to.have.property(\"id\");\r",
                  "        pm.expect(response.id).to.not.be.null;\r",
                  "        pm.expect(response.id).to.be.a(\"string\");\r",
                  "        pm.environment.set(\"ACCOUNT_ID2\", response.id); \r",
                  "    \r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{USER_TOKEN2}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"accountType\": \"SAVINGS\",\r\n    \"currency\": \"EUR\",\r\n    \"alias\": \"Creacion cuenta de ahorro (funciona si es menos de 3 cuentas para el cliente)\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{ACCOUNT_URL}}/api/accounts",
              "host": [
                "{{ACCOUNT_URL}}"
              ],
              "path": [
                "api",
                "accounts"
              ]
            }
          },
          "response": []
        }
      ]
    },
